# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/wedding

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Whitelist — comma-separated emails allowed to access the dashboard
AUTH_WHITELIST=admin@example.com,hr@example.com

# CORS — comma-separated allowed origins
CORS_ORIGIN=http://localhost:3000,https://your-dashboard.vercel.app

# Cloudinary (existing)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

#VAPID keys for web push notifications
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@yoursite.com
